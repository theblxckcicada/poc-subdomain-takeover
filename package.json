{
  "name": "ovawatch-poc-origin",
  "version": "1.0.0",
  "description": "Generic, safe Angular origin page for authorized subdomain takeover proof-of-concept reports.",
  "author": "Ovawatch / theblxckcicada",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --port 4200",
    "build": "ng build --configuration production",
